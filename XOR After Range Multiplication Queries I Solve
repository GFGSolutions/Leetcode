class Solution {
  public int xorAfterQueries(int[] nums, int[][] queries) {
    long MOD = 1000000007L;
    for (int[] q : queries) {
      int l = q[0];
      int r = q[1];
      int k = q[2];
      int v = q[3];
      for (int i = l; i <= r; i += k) {
        nums[i] = (int)((1L * nums[i] * v) % MOD);
      }
    }
    int ans = 0;
    for (int num : nums) {
      ans ^= num;
    }
    return ans;
  }
}
